{
  "manifest_version": 3,
  "name": "vadgr-computer-use browser tier",
  "version": "0.4.0",
  "description": "DOM-first browser automation bridged to vadgr-computer-use over native messaging.",
  "key": "",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabs", "cookies", "nativeMessaging", "offscreen", "scripting", "debugger"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
